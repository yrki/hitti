# Hitti - lokal utviklingskonfigurasjon
# Kopier denne filen til `.env` og fyll inn ekte verdier.
# `.env` er gitignored og skal ALDRI committes.

# Postgres
POSTGRES_USER=admin
POSTGRES_PASSWORD=change-me-locally
POSTGRES_DB=hitti

# JWT - generer en tilfeldig streng på minst 32 tegn, f.eks. `openssl rand -base64 48`
JWT_KEY=change-me-to-a-random-string-at-least-32-chars-long

# Azure Communication Services
# Hent fra Azure-portalen. Roter nøkkelen ved mistanke om lekkasje.
AZURE_COMMUNICATION_CONNECTION_STRING=endpoint=https://<din-ressurs>.communication.azure.com/;accesskey=<din-nokkel>
AZURE_COMMUNICATION_SMS_FROM=+4700000000
AZURE_COMMUNICATION_EMAIL_FROM=DoNotReply@<din-domene>.azurecomm.net

# App
APP_BASE_URL=http://localhost:3000
# I dev-modus rutes ALL utgående e-post hit. La stå tom for å sende til ekte adresser.
APP_DEV_REDIRECT_EMAIL=
